{
  "name": "w4change",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "typecheck": "tsc -b apps/web packages/domain",
    "lint": "oxlint . && node scripts/check-banned-words.mjs",
    "lint:banned-words": "node scripts/check-banned-words.mjs",
    "format": "oxfmt --write .",
    "test": "vitest run",
    "storybook": "pnpm --filter web storybook"
  },
  "devDependencies": {
    "oxfmt": "0.50.0",
    "oxlint": "1.64.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
